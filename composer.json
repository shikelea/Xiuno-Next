{
    "name": "xiuno/xiunobbs",
    "description": "Xiuno BBS 4.0 - A lightweight, high-performance PHP forum software",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Xiuno Team",
            "email": "xiuno@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "autoload": {
        "files": [
            "xiunophp/xiunophp.php"
        ]
    }
}
